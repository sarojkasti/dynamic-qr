# Fonepay third-party Dynamic QR API
FONEPAY_INTEGRATION_MODE=dynamic_api
FONEPAY_DYNAMIC_URL=https://merchantapi.fonepay.com/api/merchant/merchantDetailsForThirdParty
FONEPAY_MERCHANT_CODE=YOUR_MERCHANT_CODE
FONEPAY_MERCHANT_SECRET=YOUR_SECRET_KEY
FONEPAY_USERNAME=YOUR_USERNAME
FONEPAY_PASSWORD=YOUR_PASSWORD

# Optional: you can set the full download endpoint instead of the base URL above.
# FONEPAY_DYNAMIC_DOWNLOAD_URL=https://merchantapi.fonepay.com/api/merchant/merchantDetailsForThirdParty/thirdPartyDynamicQrDownload

# Optional: POS/form Dynamic QR API fallback when FONEPAY_INTEGRATION_MODE is not dynamic_api.
